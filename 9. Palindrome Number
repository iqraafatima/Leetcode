public:
    bool isPalindrome(int x) {
        int rev=0;
        int org=x;
        while(x>0){
            int last_dig=x%10;
             x=x/10;

            if(rev>INT_MAX/10 || rev==INT_MAX/10 && last_dig>7)
            return 0;
            if(rev<INT_MIN/10 || rev==INT_MIN/10 && last_dig<-8)
            return 0;
            rev=(rev*10)+last_dig;
        }
        if(org==rev)
        return true;
        else
        return false;
    }
};
